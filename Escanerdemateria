class GestaoEnergia:
    def __init__(self, bateria_inicial):
        self.nivel = bateria_inicial

    def consumir(self, modo_escaneamento):
        # O modo de longo alcance consome muito mais energia
        custos = {"curto": 5, "longo": 50}
        self.nivel -= custos.get(modo_escaneamento, 10)
        return self.nivel

