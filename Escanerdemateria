def identificar_materia_desconhecida(self, densidade, condutividade, raio_x_atomo):
    # Tenta buscar na base de dados existente
    resultado = self.tabela_periodica.get(str(raio_x_atomo))
    
    if resultado:
        return f"Material Identificado: {resultado['nome']}"
    
    # Se não encontrar, entra no protocolo de Matéria Desconhecida
    else:
        # Gera uma assinatura baseada nas propriedades físicas
        assinatura_hash = f"ANOMALIA-{densidade}-{raio_x_atomo}"
        
        print(f"--- ALERTA: MATÉRIA NÃO CATALOGADA ---")
        print(f"Assinatura Detectada: {assinatura_hash}")
        
        # Lógica de classificação preliminar
        if densidade > 20:
            classificacao = "Matéria Ultra-Densa (Provável Núcleo Estelar ou Origem Externa)"
        elif condutividade == "Infinita":
            classificacao = "Supercondutor Desconhecido"
        else:
            classificacao = "Composto Orgânico ou Mineral Não Identificado"
            
        return {
            "status": "Desconhecido",
            "ID_Temporario": assinatura_hash,
            "Classificacao_Provavel": classificacao,
            "Aviso": "Recomenda-se isolamento da amostra para análise em laboratório Arcturiano."
        }

def identificar_anomalia(self, densidade, condutividade, raio_x_num):
        # Primeiro, verifica se o Raio-X bate com algo conhecido na Tabela Periódica
        # (Considerando que você adicionou a tabela_periodica no seu __init__)
        resultado = self.tabela_periodica.get(str(raio_x_num))
        
        if resultado:
            return f"Identificado: {resultado['nome']}"
        
        # Se não houver correspondência, inicia o Protocolo de Anomalias
        else:
            # Gera um código de rastreio único para esta descoberta
            id_desconhecido = f"UNK-{densidade}-{int(time.time()) % 1000}"
            
            # Tenta classificar o tipo de matéria pelas propriedades físicas
            if densidade > 22.5:
                categoria = "Matéria Hiperdensa (Possível origem não-terrestre)"
            elif densidade < 0.1:
                categoria = "Plasma ou Matéria Gasosa Exótica"
            else:
                categoria = "Composto Complexo Desconhecido"
                
            return {
                "Alerta": "!!! ANOMALIA DETECTADA !!!",
                "Assinatura": id_desconhecido,
                "Classificação Preliminar": categoria,
                "Ação": "Dados enviados para o banco de dados Arcturiano para comparação."
            }

def priorizar_alvos(self, lista_materiais_detectados):
    """
    Recebe uma lista de leituras e decide qual é a mais importante.
    """
    print("[*] Analisando múltiplos sinais simultâneos...")
    
    alvo_principal = None
    nivel_prioridade = 0

    for material in lista_materiais_detectados:
        # Prioridade máxima: Anomalias e Materiais Exóticos
        if material['tipo'] == "Anomalia" or material['densidade'] > 25:
            if nivel_prioridade < 3:
                alvo_principal = material
                nivel_prioridade = 3
        
        # Prioridade média: Metais Valiosos
        elif material['nome'] in ["Ouro", "Hematita"]:
            if nivel_prioridade < 2:
                alvo_principal = material
                nivel_prioridade = 2

    if alvo_principal:
        return f"!!! FOCO PRIORITÁRIO DEFINIDO: {alvo_principal['nome']} (Nível {nivel_prioridade})"
    return "Nenhum alvo de alta relevância detectado no momento."

def validador_sistema(cor_status, valor_numerico):
    # O sistema checa se a cor "mente" para o engenheiro
    if cor_status == "Verde" and valor_numerico > 1000:
        return "ALERTA: Divergência detectada! Cor não condiz com a Telemetria."
    
    if cor_status == "Vermelho" and valor_numerico < 10:
        return "LOG: Falso positivo detectado no sensor."

    return "Sistemas sincronizados."
